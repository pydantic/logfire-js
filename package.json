{
  "name": "@pydantic/logfire-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "vp config",
    "build": "vp run --filter \"./packages/*\" build",
    "dev": "vp run --filter \"./packages/*\" --parallel dev",
    "test": "vp run --filter \"./packages/*\" test",
    "typecheck": "vp run --filter \"./packages/*\" typecheck",
    "lint": "vp lint",
    "format": "vp fmt . --write",
    "format-check": "vp fmt --check",
    "check": "pnpm run build && vp check && pnpm run typecheck && pnpm run test && pnpm run test:release-tooling",
    "release": "pnpm run build && pnpm publish -r --access public",
    "changeset-add": "pnpm changeset add",
    "test:release-tooling": "node scripts/create-npm-token.test.mjs",
    "verify:browser-rum-release-plan": "node scripts/verify-browser-release-plan.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@voidzero-dev/vite-plus-core": "0.2.1",
    "typescript": "catalog:",
    "vite-plus": "0.2.1"
  },
  "engines": {
    "node": "24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.14.1 <25",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@11.5.2"
}
