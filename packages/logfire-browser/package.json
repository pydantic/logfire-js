{
  "name": "@pydantic/logfire-browser",
  "description": "JavaScript Browser SDK for Logfire - https://pydantic.dev/logfire",
  "author": {
    "name": "The Pydantic Team",
    "email": "engineering@pydantic.dev",
    "url": "https://pydantic.dev"
  },
  "repository": {
    "url": "https://github.com/pydantic/logfire-js",
    "directory": "packages/logfire-browser"
  },
  "sideEffects": false,
  "homepage": "https://pydantic.dev/logfire",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "logfire",
    "observability",
    "opentelemetry",
    "tracing",
    "profiling",
    "stats",
    "monitoring"
  ],
  "version": "0.14.2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./evals": {
      "import": {
        "types": "./dist/evals.d.ts",
        "default": "./dist/evals.js"
      },
      "require": {
        "types": "./dist/evals.d.cts",
        "default": "./dist/evals.cjs"
      }
    }
  },
  "scripts": {
    "dev": "vite build",
    "build": "vite build",
    "lint": "eslint",
    "preview": "vite preview",
    "typecheck": "tsc",
    "prepack": "cp ../../LICENSE .",
    "postpack": "rm LICENSE",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/core": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/instrumentation": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "logfire": "workspace:*"
  },
  "peerDependencies": {
    "@opentelemetry/sdk-trace-web": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-web": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "user-agent-data-types": "^0.4.2"
  },
  "files": [
    "dist",
    "LICENSE"
  ]
}
