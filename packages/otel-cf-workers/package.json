{
  "name": "@pydantic/otel-cf-workers",
  "private": false,
  "description": "OpenTelemetry instrumentation for Cloudflare Workers used by Logfire - https://pydantic.dev/logfire",
  "author": {
    "name": "The Pydantic Team",
    "email": "engineering@pydantic.dev",
    "url": "https://pydantic.dev"
  },
  "repository": {
    "url": "git+https://github.com/pydantic/logfire-js.git",
    "directory": "packages/otel-cf-workers"
  },
  "sideEffects": true,
  "homepage": "https://pydantic.dev/logfire",
  "license": "BSD-3-Clause",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "opentelemetry",
    "tracing",
    "instrumentation"
  ],
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
