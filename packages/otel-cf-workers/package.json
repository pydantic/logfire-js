    "preview": "vp preview",
    "typecheck": "tsc",
    "test": "vp test"
  },
  "dependencies": {
    "@opentelemetry/core": "catalog:",
    "@opentelemetry/otlp-exporter-base": "catalog:",
    "@opentelemetry/otlp-transformer": "catalog:",
