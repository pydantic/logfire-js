{
  "name": "logfire",
  "private": false,
  "description": "JavaScript API for Logfire - https://pydantic.dev/logfire",
  "author": {
    "name": "The Pydantic Team",
    "email": "engineering@pydantic.dev",
    "url": "https://pydantic.dev"
  },
  "repository": {
    "url": "https://github.com/pydantic/logfire-js",
    "directory": "packages/logfire-api"
  },
  "sideEffects": false,
  "homepage": "https://pydantic.dev/logfire",
  "bugs": {
    "url": "https://github.com/pydantic/logfire-js/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "logfire",
    "observability",
    "opentelemetry",
    "tracing",
    "profiling",
    "stats",
    "monitoring"
  ],
  "version": "0.20.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "logfire": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./evals": {
      "import": {
        "types": "./dist/evals.d.ts",
        "default": "./dist/evals.js"
      },
      "require": {
        "types": "./dist/evals.d.cts",
        "default": "./dist/evals.cjs"
      }
    },
    "./datasets": {
      "import": {
        "types": "./dist/datasets.d.ts",
        "default": "./dist/datasets.js"
      },
      "require": {
        "types": "./dist/datasets.d.cts",
        "default": "./dist/datasets.cjs"
      }
    },
    "./vars": {
      "import": {
        "types": "./dist/vars.d.ts",
        "default": "./dist/vars.js"
      },
      "require": {
        "types": "./dist/vars.d.cts",
        "default": "./dist/vars.cjs"
      }
    },
    "./vars/reference-syntax": {
      "import": {
        "types": "./dist/vars/reference-syntax.d.ts",
        "default": "./dist/vars/reference-syntax.js"
      },
      "require": {
        "types": "./dist/vars/reference-syntax.d.cts",
        "default": "./dist/vars/reference-syntax.cjs"
      }
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "coverage:evals": "node -e \"console.warn('coverage:evals is temporarily disabled during the Vite+ migration.')\"",
    "lint": "vp lint",
    "preview": "vp preview",
    "typecheck": "tsc",
    "prepack": "cp ../../LICENSE .",
    "postpublish": "rm LICENSE",
    "test": "vp test"
  },
  "dependencies": {
    "handlebars": "catalog:",
    "js-yaml": "catalog:",
    "p-retry": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/api-logs": "catalog:",
    "@opentelemetry/context-async-hooks": "catalog:",
    "@opentelemetry/sdk-logs": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@types/js-yaml": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/api-logs": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api-logs": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ]
}
