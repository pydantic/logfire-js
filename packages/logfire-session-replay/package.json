{
  "name": "@pydantic/logfire-session-replay",
  "description": "Browser session replay recorder for Logfire - https://pydantic.dev/logfire",
  "author": {
    "name": "The Pydantic Team",
    "email": "engineering@pydantic.dev",
    "url": "https://pydantic.dev"
  },
  "repository": {
    "url": "https://github.com/pydantic/logfire-js",
    "directory": "packages/logfire-session-replay"
  },
  "sideEffects": false,
  "homepage": "https://pydantic.dev/logfire",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "logfire",
    "observability",
    "session-replay",
    "browser",
    "rum",
    "rrweb"
  ],
  "version": "0.1.0-alpha.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "lint": "vp lint",
    "preview": "vp preview",
    "typecheck": "tsc",
    "prepack": "cp ../../LICENSE .",
    "postpublish": "rm LICENSE",
    "test": "vp test"
  },
  "dependencies": {
    "fflate": "catalog:",
    "rrweb": "catalog:"
  },
  "devDependencies": {
    "jsdom": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "LICENSE"
  ]
}
