# Development-only server settings. The token is read only by the Express proxy.
HOST=127.0.0.1
PORT=8989
LOGFIRE_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:4173
LOGFIRE_URL=https://logfire-api.pydantic.dev/v1/traces
LOGFIRE_METRICS_URL=https://logfire-api.pydantic.dev/v1/metrics
LOGFIRE_REPLAY_URL=https://logfire-api.pydantic.dev/v1/replay
LOGFIRE_TOKEN=<your-logfire-write-token>

# Vite forwards same-origin /api and /client-* requests to this loopback server.
LOGFIRE_PROXY_TARGET=http://127.0.0.1:8989
